# ============================================================================
# PROTECH — Render production env vars (single-service deploy)
# ============================================================================
# Copy each value into Render → your service → Environment. This file is a
# CHECKLIST, not something Render reads automatically — do not commit a real
# copy of it with secrets filled in (keep it out of git, same as .env).
#
# Vars marked (auto) are already set by render.yaml and don't need manual entry.
# Vars marked (required) must be filled in by hand in the Render dashboard.
# ============================================================================

# ---- Server (auto via render.yaml / Render platform) ----
NODE_ENV=production
USE_EMBEDDED_DB=false
JWT_EXPIRES_IN=7d
JWT_SECRET=                      # (auto) Render generates this on first deploy
PORT=                            # (auto) Render injects this itself — do not set manually

# ---- Database (required) ----
# MongoDB Atlas free-tier (M0) connection string. Create a cluster at
# https://cloud.mongodb.com, add a database user, allow network access from
# 0.0.0.0/0 (Render's egress IPs aren't static on the free plan), then copy
# the connection string here.
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/prostech

# ---- Email — supervisor verification codes (required) ----
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (regular Gmail passwords won't work with SMTP). Leave SMTP_USER/PASS blank
# to run in dev mode (codes logged to the Render service logs instead of sent).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PROTECH <no-reply@prostech.edu>

# ---- Cloudinary — project document uploads (required) ----
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================================
# NOT needed anymore:
#  - CLIENT_URL / VITE_API_URL — the client is now served by this same Render
#    service (same origin), so no cross-origin config is required.
#  - Any Vercel project/env vars — the client no longer deploys separately.
# ============================================================================
