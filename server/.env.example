# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
# Local dev convenience only (spins up an in-memory MongoDB). Never set true in prod.
USE_EMBEDDED_DB=false

# ---- Database ----
# Local:  mongodb://127.0.0.1:27017/prostech
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/prostech
MONGO_URI=mongodb://127.0.0.1:27017/prostech

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Admin account creation ----
# Admin is never publicly self-serve — registering at the admin gateway only
# succeeds if the form's "Admin Setup Key" field matches this exactly (also
# capped at 3 admin accounts total regardless of key). Blank = admin
# registration is closed entirely, even with a key.
ADMIN_SETUP_KEY=

# ---- Cloudinary (file uploads) ----
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email (supervisor verification) ----
# Sent via Brevo's HTTPS API (https://api.brevo.com) rather than raw SMTP —
# most PaaS free tiers (including Render) block outbound SMTP ports entirely.
# Get an API key at https://app.brevo.com/settings/keys/api and verify a
# single sender email at https://app.brevo.com/senders (no domain/DNS needed).
# If BREVO_API_KEY is left blank, verification codes are logged to the server
# console instead (dev mode).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=PROTECH
