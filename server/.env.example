# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
# Local dev convenience only (spins up an in-memory MongoDB). Never set true in prod.
USE_EMBEDDED_DB=false

# ---- Database ----
# Local:  mongodb://127.0.0.1:27017/prostech
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/prostech
MONGO_URI=mongodb://127.0.0.1:27017/prostech

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Cloudinary (file uploads) ----
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email (supervisor verification) ----
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
# If left blank, verification codes are logged to the server console (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PROTECH <no-reply@prostech.edu>
